{
  "build": {
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EAS_BUILD_BUN_ENABLED": "0",
        "EAS_BUILD_SKIP_EXPO_DOCTOR": "true",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
        "NPM_FLAGS": "--no-package-lock"
      }
    }
  }
}

